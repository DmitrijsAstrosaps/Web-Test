}
tr:hover td{
    background-color: yellow;
}
td:hover{
    background-color: gold!important;
}
td:hover::after {
    content: "";
    position: absolute;
    background-color: yellow;
    left: 0;
    top: -5000px;
    height: 10000px;
    width: 100%;
    z-index: -1;
}
td:hover .apl{
    background-color: black;
}
